<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Avalonia.Editors.Gallery.MainWindow"
        Title="Bee Field Editors Gallery — Semi.Avalonia"
        Width="1000" Height="780">

  <DockPanel Margin="16">

    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
      <ToggleSwitch x:Name="ThemeToggle"
                    DockPanel.Dock="Right"
                    OnContent="Dark" OffContent="Light"
                    IsCheckedChanged="OnThemeToggled" />
      <StackPanel Orientation="Vertical" Spacing="2">
        <TextBlock Text="Field Editor 樣式比對" FontSize="20" FontWeight="Bold" />
        <TextBlock Text="左：原生 Avalonia 控件（手動設值）　右：繼承控件（FormScope ambient 綁定，輸入會即時寫回下方 FormDataObject）"
                   FontSize="12" Opacity="0.7" />
      </StackPanel>
    </DockPanel>

    <Border DockPanel.Dock="Bottom"
            Margin="0,12,0,0" Padding="12"
            BorderThickness="1" BorderBrush="Gray" CornerRadius="4">
      <StackPanel Spacing="4">
        <TextBlock Text="FormDataObject 即時欄位值" FontWeight="SemiBold" />
        <TextBlock x:Name="ValuesText" FontFamily="Menlo,Consolas,monospace" FontSize="12" />
      </StackPanel>
    </Border>

    <ScrollViewer>
      <StackPanel x:Name="GalleryHost" Spacing="16" Margin="0,0,12,0" />
    </ScrollViewer>

  </DockPanel>

</Window>
