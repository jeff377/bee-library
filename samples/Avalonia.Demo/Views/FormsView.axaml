<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Avalonia.Demo.ViewModels"
             xmlns:local="clr-namespace:Avalonia.Demo"
             mc:Ignorable="d"
             x:Class="Avalonia.Demo.Views.FormsView"
             x:DataType="vm:FormsViewModel">

  <!-- Each tab hosts a FormWorkspace: a ListView (browse) that swaps to a FormView
       (single record) on View / Edit / New, following the ERP list/record split. The
       workspace only needs the ProgId; ListView and FormView resolve schema / connector /
       token from ClientInfo. Project demonstrates the lookup flow. -->
  <TabControl Margin="12">
    <TabItem Header="Employee">
      <local:FormWorkspace ProgId="Employee" />
    </TabItem>
    <TabItem Header="Department">
      <local:FormWorkspace ProgId="Department" />
    </TabItem>
    <TabItem Header="Project">
      <local:FormWorkspace ProgId="Project" />
    </TabItem>
  </TabControl>

</UserControl>
