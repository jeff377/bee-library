<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Avalonia.Demo.ViewModels"
             xmlns:bee="clr-namespace:Bee.UI.Avalonia.Controls;assembly=Bee.UI.Avalonia"
             mc:Ignorable="d"
             x:Class="Avalonia.Demo.Views.EmployeeView"
             x:DataType="vm:EmployeeViewModel">

  <ScrollViewer>
    <StackPanel Margin="12" Spacing="12">
      <!-- FormView resolves Schema / FormConnector / AccessToken from ClientInfo
           via its built-in fallback; we only have to set ProgId. -->
      <bee:FormView ProgId="Employee" />
    </StackPanel>
  </ScrollViewer>

</UserControl>
