<?xml version="1.0" encoding="utf-8"?>
<TableSchema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" DbName="log" TableName="st_log_login" DisplayName="登入記錄">
	<Fields>
		<DbField FieldName="sys_no" Caption="流水號" DbType="AutoIncrement" />
		<DbField FieldName="sys_rowid" Caption="唯一識別" DbType="Guid" />
		<DbField FieldName="log_time" Caption="事件時刻" DbType="DateTime" />
		<DbField FieldName="user_id" Caption="使用者帳號" DbType="String" Length="50" AllowNull="true" />
		<DbField FieldName="user_name" Caption="使用者名稱" DbType="String" Length="100" AllowNull="true" />
		<DbField FieldName="company_id" Caption="公司代碼" DbType="String" Length="50" AllowNull="true" />
		<DbField FieldName="company_name" Caption="公司名稱" DbType="String" Length="100" AllowNull="true" />
		<DbField FieldName="access_token" Caption="存取令牌" DbType="Guid" AllowNull="true" />
		<DbField FieldName="trace_id" Caption="關聯識別" DbType="Guid" AllowNull="true" />
		<DbField FieldName="client_ip" Caption="來源位址" DbType="String" Length="45" AllowNull="true" />
		<DbField FieldName="source" Caption="來源標記" DbType="String" Length="100" AllowNull="true" />
		<DbField FieldName="event" Caption="事件類型" DbType="Integer" />
		<DbField FieldName="fail_reason" Caption="失敗原因" DbType="String" Length="200" AllowNull="true" />
	</Fields>
	<Indexes>
		<DbTableIndex Name="pk_{0}" Unique="true" PrimaryKey="true">
			<IndexFields>
				<IndexField FieldName="sys_no" />
			</IndexFields>
		</DbTableIndex>
		<DbTableIndex Name="rx_{0}" Unique="true">
			<IndexFields>
				<IndexField FieldName="sys_rowid" />
			</IndexFields>
		</DbTableIndex>
	</Indexes>
</TableSchema>
