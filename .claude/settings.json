      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(python3:*)",
      "Bash(mkdir:*)",
      "Bash(date:*)",
      "Bash(TZ=Asia/Taipei date:*)",
      "WebFetch(domain:sonarcloud.io)"
    ]
  }
}
