<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0-ios</TargetFramework>
    <SupportedOSPlatformVersion>13.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Bee.Northwind.iOS</RootNamespace>
    <AssemblyName>Bee.Northwind.iOS</AssemblyName>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <!--
      Debug-first head. Unlike the other Northwind heads this deliberately does NOT set
      TreatWarningsAsErrors: the iOS build runs trim analysis and Bee's reflection-heavy
      serialization (XmlSerializer for FormSchema, System.Text.Json, MessagePack) emits
      IL2026 / IL2104 trim warnings that are expected here. Release / trim-safe packaging
      is a separate follow-up (see .claude/rules/maui.md Apple trim decision tree).
    -->
  </PropertyGroup>

  <!--
    Debug runs on the simulator under the Mono interpreter (no AOT), so disable the managed
    linker entirely. Bee (de)serializes FormSchema / DataSet via reflection (XmlSerializer,
    System.Text.Json, MessagePack); with trimming on, ILLink strips those paths and the app
    fails at runtime with "XmlSerializeErrorDetails 2,2" (see .claude/rules/maui.md). Release
    trim-safe packaging is a separate follow-up; MtouchLink=None must NOT be used for Release
    (it breaks AOT). Scoped to Debug only.
  -->
  <PropertyGroup Condition="'$(Configuration)' == 'Debug'">
    <MtouchLink>None</MtouchLink>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia.iOS" Version="12.0.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Bee.Northwind.UI\Bee.Northwind.UI.csproj" />
  </ItemGroup>

</Project>
