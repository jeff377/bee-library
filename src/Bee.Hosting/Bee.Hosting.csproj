<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Description>Composition root for the Bee.NET framework. Registers backend services into any IServiceCollection — usable from ASP.NET Core, WinForms/WPF, Console, Worker Service, and integration test hosts without pulling in ASP.NET Core.</Description>
    <PackageTags>bee.net;di;composition;hosting;backend</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Bee.Api.Core\Bee.Api.Core.csproj" />
    <ProjectReference Include="..\Bee.Business\Bee.Business.csproj" />
    <ProjectReference Include="..\Bee.Expressions\Bee.Expressions.csproj" />
    <ProjectReference Include="..\Bee.Repository\Bee.Repository.csproj" />
    <ProjectReference Include="..\Bee.ObjectCaching\Bee.ObjectCaching.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Bee.Hosting.UnitTests" />
  </ItemGroup>

</Project>
