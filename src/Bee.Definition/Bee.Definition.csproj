<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <Description>Defines system-wide structured types for config, schema, and layout.</Description>
    <PackageTags>bee.net;config;schema;layout;formdefine;enterprise</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MessagePack" Version="3.1.7" />
    <PackageReference Include="Microsoft.Extensions.Localization.Abstractions" Version="10.0.8" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Bee.Base\Bee.Base.csproj" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Bee.Business" />
    <InternalsVisibleTo Include="Bee.Definition.UnitTests" />
  </ItemGroup>

  <!--
    Trimmer / AOT preservation roots for the definition layer, shipped with the package.
    The logical name "ILLink.Descriptors.xml" is the convention the .NET trimmer scans for,
    so this is auto-applied for every downstream trimmed / AOT consumer (e.g. the Avalonia
    iOS / Android heads). See ILLink.Descriptors.xml and
    docs/plans/plan-mobile-release-trim-safe.md.
  -->
  <ItemGroup>
    <EmbeddedResource Include="ILLink.Descriptors.xml">
      <LogicalName>ILLink.Descriptors.xml</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

  <!--
    Framework default definitions (TableSchema / FormSchema / FormLayout / Language / DbCategorySettings)
    embedded as manifest resources. Consumed by Bee.Definition.Defaults.Defaults APIs.

    LogicalName pattern uses '/' as separator (not '.') so the relative path round-trips
    unambiguously - filenames contain '.' (e.g. st_user.TableSchema.xml) which would
    otherwise collide with directory separators.

    e.g. Defaults/TableSchema/common/st_user.TableSchema.xml
         -> Bee.Definition.Defaults/TableSchema/common/st_user.TableSchema.xml
  -->
  <ItemGroup>
    <EmbeddedResource Include="Defaults\**\*.xml">
      <LogicalName>Bee.Definition.Defaults/$([System.String]::Copy('%(RecursiveDir)').Replace('\','/'))%(Filename)%(Extension)</LogicalName>
    </EmbeddedResource>
  </ItemGroup>

</Project>
