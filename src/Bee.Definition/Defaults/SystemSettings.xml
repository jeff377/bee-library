<?xml version="1.0" encoding="utf-8"?>
<!--
  Framework-shipped SystemSettings template.

  After materialising via `Bee.Definition.Defaults.MaterializeTo(...)`, review the
  fields below and adjust for your deployment. The defaults here are conservative
  (debug mode off, no namespaces allow-listed for cross-tier type resolution) so
  the application boots in a production-shaped state out of the box.

  Required field to set before first run:
    - BackendConfiguration/SecurityKeySettings/MasterKeySource
      Default points at the `BEE_MASTER_KEY` environment variable. Set the env
      var (a Base64 AES-CBC-HMAC combined 64-byte key) or change Type to
      AzureKeyVault / File and supply the corresponding Value.

  Optional fields to consider:
    - CommonConfiguration/IsDebugMode: enable verbose error responses for
      development environments.
    - CommonConfiguration/AllowedTypeNamespaces: comma-separated allow-list of
      namespaces that may be deserialised across the API tier. Empty means no
      consumer-defined types are accepted (framework types always allowed).
    - BackendConfiguration/LogOptions/DbAccess: thresholds for slow-query /
      large-resultset logging.
    - BackendConfiguration/Components: bind custom factories (e.g. a custom
      BusinessObjectProvider) when overriding framework defaults.
-->
<SystemSettings xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <CommonConfiguration>
    <Version>1.0.0</Version>
    <IsDebugMode>false</IsDebugMode>
    <AllowedTypeNamespaces></AllowedTypeNamespaces>
    <ApiPayloadOptions>
      <Serializer>messagepack</Serializer>
      <Compressor>gzip</Compressor>
      <Encryptor>aes-cbc-hmac</Encryptor>
    </ApiPayloadOptions>
  </CommonConfiguration>
  <BackendConfiguration>
    <LogOptions>
      <DbAccess>
        <Level>Warning</Level>
        <AffectedRowThreshold>10000</AffectedRowThreshold>
        <ResultRowThreshold>10000</ResultRowThreshold>
        <ExecutionTimeThreshold>300</ExecutionTimeThreshold>
      </DbAccess>
    </LogOptions>
    <SecurityKeySettings>
      <MasterKeySource>
        <Type>Environment</Type>
        <Value>BEE_MASTER_KEY</Value>
      </MasterKeySource>
    </SecurityKeySettings>
    <Components>
      <BusinessObjectProvider></BusinessObjectProvider>
    </Components>
  </BackendConfiguration>
  <FrontendConfiguration />
  <WebsiteConfiguration />
  <BackgroundServiceConfiguration />
</SystemSettings>
