		<DbField FieldName="log_time" Caption="事件時刻" DbType="DateTime" />
		<DbField FieldName="user_id" Caption="使用者帳號" DbType="String" Length="50" AllowNull="true" />
		<DbField FieldName="user_name" Caption="使用者名稱" DbType="String" Length="100" AllowNull="true" />
		<DbField FieldName="company_id" Caption="公司代碼" DbType="String" Length="50" AllowNull="true" />
