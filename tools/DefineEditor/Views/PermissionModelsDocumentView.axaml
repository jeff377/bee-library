<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:settings="using:Bee.Definition.Settings"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Bee.DefineEditor.Views.PermissionModelsDocumentView"
             x:DataType="vm:PermissionModelsDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="settings:PermissionModel">
            <StackPanel x:DataType="settings:PermissionModel" Spacing="6">
                <TextBlock Text="PermissionModel 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="ModelId"/>
                    <TextBox Text="{Binding ModelId, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="settings:PermissionRule">
            <StackPanel x:DataType="settings:PermissionRule" Spacing="6">
                <TextBlock Text="PermissionRule 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Action"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.PermissionActions}"
                              SelectedItem="{Binding Action, Mode=TwoWay}" Width="240"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Scope"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.ScopeStrategies}"
                              SelectedItem="{Binding Scope, Mode=TwoWay}" Width="240"/>
                </StackPanel>
                <TextBlock Text="（Print / Export 為輸出動作，Scope 應留在 Inherit；其他 action 可自由指定。）"
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="settings:PermissionModels">
            <StackPanel Spacing="6">
                <TextBlock Text="PermissionModels（registry 根節點）" FontWeight="Bold" FontSize="13"/>
                <TextBlock Text="於工具列「新增 Model」加入 PermissionModel；選取 Model 後可「新增 Rule」加入該 Model 的 PermissionRule。"
                           Foreground="#A0A0A0" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="12,8" Background="#1F1F22">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="#FFFFFF"/>
                        <TextBlock Text="●" Foreground="#E0A33A" VerticalAlignment="Center"
                                   IsVisible="{Binding IsDirty}" ToolTip.Tip="尚未存檔"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#A0A0A0"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="doc" Content="儲存" Command="{Binding SaveCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Model" Command="{Binding AddModelCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Rule" Command="{Binding AddRuleCommand}" Margin="3"/>
                    <Button Classes="doc" Content="驗證" Command="{Binding ValidateCommand}" Margin="3"/>
                    <Button Classes="doc danger" Content="刪除" Command="{Binding DeleteCommand}" Margin="3"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="12,4" Background="#1F1F22">
            <TextBlock Text="{Binding StatusText}" Foreground="#A0A0A0" FontSize="11"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="10,6" Background="#252528"
                IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Foreground="#E0E0E0" Text="驗證結果"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="150" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}"/>
                                <TextBlock Text="{Binding Path}" Foreground="#A0A0A0" Width="220"/>
                                <TextBlock Text="{Binding Message}" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.2*">
            <TreeView Grid.Column="0"
                      ItemsSource="{Binding Roots}"
                      SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Icon}"/>
                            <TextBlock Text="{Binding Header}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
            </TreeView>

            <GridSplitter Grid.Column="1" Background="#3E3E42" ResizeDirection="Columns"/>

            <Border Grid.Column="2" Padding="14">
                <ScrollViewer>
                    <ContentControl Content="{Binding SelectedEditorContext}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
