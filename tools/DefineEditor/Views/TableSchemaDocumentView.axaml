<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:db="using:Bee.Definition.Database"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Bee.DefineEditor.Views.TableSchemaDocumentView"
             x:DataType="vm:TableSchemaDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="db:TableSchema">
            <StackPanel x:DataType="db:TableSchema" Spacing="6">
                <TextBlock Text="TableSchema 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="TableName"/>
                    <TextBox Text="{Binding TableName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="db:DbField">
            <StackPanel x:DataType="db:DbField" Spacing="6">
                <TextBlock Text="DbField 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="FieldName"/>
                    <TextBox Text="{Binding FieldName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Caption"/>
                    <TextBox Text="{Binding Caption, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DbType"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.FieldDbTypes}"
                              SelectedItem="{Binding DbType, Mode=TwoWay}" Width="200"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Length (String)"/>
                    <TextBox Text="{Binding Length, Mode=TwoWay}" Width="120"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Precision (Decimal)"/>
                    <TextBox Text="{Binding Precision, Mode=TwoWay}" Width="120"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Scale (Decimal)"/>
                    <TextBox Text="{Binding Scale, Mode=TwoWay}" Width="120"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="AllowNull"/>
                    <CheckBox IsChecked="{Binding AllowNull, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DefaultValue"/>
                    <TextBox Text="{Binding DefaultValue, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="OriginalFieldName"/>
                    <TextBox Text="{Binding OriginalFieldName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <TextBlock Text="（OriginalFieldName 是 schema upgrade 階段一次性 rename hint，平常留空。）"
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="db:DbTableIndex">
            <StackPanel x:DataType="db:DbTableIndex" Spacing="6">
                <TextBlock Text="DbTableIndex 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Name"/>
                    <TextBox Text="{Binding Name, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="PrimaryKey"/>
                    <CheckBox IsChecked="{Binding PrimaryKey, Mode=TwoWay}"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Unique"/>
                    <CheckBox IsChecked="{Binding Unique, Mode=TwoWay}"/>
                </StackPanel>
                <TextBlock Text="（用工具列「新增 IndexField」加入索引欄位。）"
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="db:IndexField">
            <StackPanel x:DataType="db:IndexField" Spacing="6">
                <TextBlock Text="IndexField 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="FieldName"/>
                    <TextBox Text="{Binding FieldName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="SortDirection"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.SortDirections}"
                              SelectedItem="{Binding SortDirection, Mode=TwoWay}" Width="160"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="12,8" Background="#1F1F22">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="#FFFFFF"/>
                        <TextBlock Text="●" Foreground="#E0A33A" VerticalAlignment="Center"
                                   IsVisible="{Binding IsDirty}" ToolTip.Tip="尚未存檔"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#A0A0A0"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="doc" Content="儲存" Command="{Binding SaveCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Field" Command="{Binding AddFieldCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Index" Command="{Binding AddIndexCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 IndexField" Command="{Binding AddIndexFieldCommand}" Margin="3"/>
                    <Button Classes="doc" Content="驗證" Command="{Binding ValidateCommand}" Margin="3"/>
                    <Button Classes="doc danger" Content="刪除" Command="{Binding DeleteCommand}" Margin="3"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="12,4" Background="#1F1F22">
            <TextBlock Text="{Binding StatusText}" Foreground="#A0A0A0" FontSize="11"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="10,6" Background="#252528"
                IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Foreground="#E0E0E0" Text="驗證結果"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="150" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}"/>
                                <TextBlock Text="{Binding Path}" Foreground="#A0A0A0" Width="220"/>
                                <TextBlock Text="{Binding Message}" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.2*">
            <TreeView Grid.Column="0"
                      ItemsSource="{Binding Roots}"
                      SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Icon}"/>
                            <TextBlock Text="{Binding Header}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
            </TreeView>

            <GridSplitter Grid.Column="1" Background="#3E3E42" ResizeDirection="Columns"/>

            <Border Grid.Column="2" Padding="14">
                <ScrollViewer>
                    <ContentControl Content="{Binding SelectedEditorContext}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
