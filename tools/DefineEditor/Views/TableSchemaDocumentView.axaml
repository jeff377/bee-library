<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:db="using:Bee.Definition.Database"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Bee.DefineEditor.Views.TableSchemaDocumentView"
             x:DataType="vm:TableSchemaDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="db:TableSchema">
            <StackPanel x:DataType="db:TableSchema" Spacing="2">
                <TextBlock Classes="h2" Text="TableSchema 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="TableName"/><TextBox Text="{Binding TableName, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="DisplayName"/><TextBox Text="{Binding DisplayName, Mode=TwoWay}"/></DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="db:DbField">
            <StackPanel x:DataType="db:DbField" Spacing="2">
                <TextBlock Classes="h2" Text="DbField 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="FieldName"/><TextBox Text="{Binding FieldName, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Caption"/><TextBox Text="{Binding Caption, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short">
                    <TextBlock Classes="label" Text="DbType"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.FieldDbTypes}" SelectedItem="{Binding DbType, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row short"><TextBlock Classes="label" Text="Length (String)"/><TextBox Text="{Binding Length, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short"><TextBlock Classes="label" Text="Precision (Decimal)"/><TextBox Text="{Binding Precision, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short"><TextBlock Classes="label" Text="Scale (Decimal)"/><TextBox Text="{Binding Scale, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="AllowNull"/><CheckBox IsChecked="{Binding AllowNull, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="DefaultValue"/><TextBox Text="{Binding DefaultValue, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="OriginalFieldName"/><TextBox Text="{Binding OriginalFieldName, Mode=TwoWay}"/></DockPanel>
                <TextBlock Classes="muted" Margin="0,8,0,0" TextWrapping="Wrap"
                           Text="（OriginalFieldName 是 schema upgrade 階段一次性 rename hint，平常留空。）"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="db:DbTableIndex">
            <StackPanel x:DataType="db:DbTableIndex" Spacing="2">
                <TextBlock Classes="h2" Text="DbTableIndex 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Name"/><TextBox Text="{Binding Name, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="PrimaryKey"/><CheckBox IsChecked="{Binding PrimaryKey, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Unique"/><CheckBox IsChecked="{Binding Unique, Mode=TwoWay}"/></DockPanel>
                <TextBlock Classes="muted" Margin="0,8,0,0" TextWrapping="Wrap" Text="（用工具列「+ IndexField」加入索引欄位。）"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="db:IndexField">
            <StackPanel x:DataType="db:IndexField" Spacing="2">
                <TextBlock Classes="h2" Text="IndexField 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="FieldName"/><TextBox Text="{Binding FieldName, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short">
                    <TextBlock Classes="label" Text="SortDirection"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.SortDirections}" SelectedItem="{Binding SortDirection, Mode=TwoWay}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>

        <Border DockPanel.Dock="Bottom" Classes="statusbar" Padding="12,5">
            <TextBlock Classes="muted" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="surface-sunken" Padding="12,8" IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="h2" Text="驗證結果"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="160" Background="Transparent" BorderThickness="0" Margin="0,6,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Path}" Classes="muted" Width="240"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.2*">
            <TreeView Grid.Column="0" ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}" Padding="6,4">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Classes="inner-icon" Data="{Binding Icon, Converter={StaticResource IconKeyToGeometry}}"/>
                            <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="新增 DbField"
                                  Command="{Binding AddFieldCommand}"
                                  IsVisible="{Binding SelectedKindIsFieldsGroup}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconColumn}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="新增 DbTableIndex"
                                  Command="{Binding AddIndexCommand}"
                                  IsVisible="{Binding SelectedKindIsIndexesGroup}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconKey}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="新增 IndexField"
                                  Command="{Binding AddIndexFieldCommand}"
                                  IsVisible="{Binding SelectedKindIsIndex}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconColumn}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator IsVisible="{Binding SelectedKindCanDelete}"/>
                        <MenuItem Header="刪除"
                                  Command="{Binding DeleteCommand}"
                                  IsVisible="{Binding SelectedKindCanDelete}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconDelete}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>
            <GridSplitter Grid.Column="1" Background="{DynamicResource SplitterBrush}" ResizeDirection="Columns"/>
            <Border Grid.Column="2" Padding="18,14">
                <ScrollViewer Classes="props-pane" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding SelectedEditorContext}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
