<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:settings="using:Bee.Definition.Settings"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="700"
             x:Class="Bee.DefineEditor.Views.DatabaseSettingsDocumentView"
             x:DataType="vm:DatabaseSettingsDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="settings:DatabaseSettings">
            <StackPanel Spacing="6">
                <TextBlock Text="DatabaseSettings 根節點" FontWeight="Bold" FontSize="13"/>
                <TextBlock Text="於工具列「新增 Server」加入 DatabaseServer，「新增 Item」加入 DatabaseItem；Server 提供共用連線字串樣板（用 {@UserId}/{@Password} 佔位符），Item 綁定 Server 或自行提供連線字串（用 {@DbName} 指定資料庫名）。"
                           Foreground="#A0A0A0" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>

        <!-- DatabaseServer wrapper editor panel -->
        <DataTemplate DataType="vm:DatabaseServerEditor">
            <StackPanel x:DataType="vm:DatabaseServerEditor" Spacing="6">
                <TextBlock Text="DatabaseServer 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Id"/>
                    <TextBox Text="{Binding Id, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DatabaseType"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.DatabaseTypes}"
                              SelectedItem="{Binding DatabaseType, Mode=TwoWay}" Width="200"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="UserId"/>
                    <TextBox Text="{Binding UserId, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Password"/>
                    <TextBox Text="{Binding Password, Mode=TwoWay}" Width="280" PasswordChar="●"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="ConnectionString"/>
                    <TextBox Text="{Binding ConnectionString, Mode=TwoWay}" Width="500"
                             AcceptsReturn="False" TextWrapping="Wrap"/>
                </StackPanel>

                <Separator Margin="0,12"/>
                <TextBlock Text="貼上連線字串拆解" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                <TextBlock Text="貼上完整連線字串後按「拆解」，工具會依目前選定的 DatabaseType 把帳密拆出來、改寫成佔位符。"
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap"/>
                <TextBox Text="{Binding PasteInput, Mode=TwoWay}" Height="80" AcceptsReturn="True"
                         TextWrapping="Wrap"
                         PlaceholderText="例：Data Source=localhost;Initial Catalog=master;User ID=sa;Password=…"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Classes="doc" Content="拆解" Command="{Binding ParseCommand}"/>
                    <Button Classes="doc" Content="清除" Command="{Binding ClearCommand}"/>
                </StackPanel>

                <Border IsVisible="{Binding HasParseResult}" Padding="10" Margin="0,8,0,0"
                        Background="#252528" CornerRadius="3">
                    <StackPanel Spacing="4" x:DataType="vm:DatabaseServerEditor">
                        <TextBlock Text="拆解預覽" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                        <TextBlock Text="{Binding ParseResult.UserId, StringFormat='UserId：{0}'}" Foreground="#D0D0D0"/>
                        <TextBlock Text="{Binding ParseResult.Password, StringFormat='Password：{0}'}" Foreground="#D0D0D0"/>
                        <TextBlock Text="{Binding ParseResult.RewrittenConnectionString, StringFormat='ConnectionString：{0}'}"
                                   Foreground="#D0D0D0" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding ParseResult.Errors}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#E55" FontSize="11" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding ParseResult.Warnings}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#E0A33A" FontSize="11" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                            <Button Classes="doc" Content="套用至此 Server" Command="{Binding ApplyCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>

        <!-- DatabaseItem wrapper editor panel -->
        <DataTemplate DataType="vm:DatabaseItemEditor">
            <StackPanel x:DataType="vm:DatabaseItemEditor" Spacing="6">
                <TextBlock Text="DatabaseItem 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Id"/>
                    <TextBox Text="{Binding Id, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="CategoryId"/>
                    <TextBox Text="{Binding CategoryId, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DatabaseType"/>
                    <ComboBox ItemsSource="{x:Static vm:SingletonEditorOptions.DatabaseTypes}"
                              SelectedItem="{Binding DatabaseType, Mode=TwoWay}" Width="200"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="ServerId"/>
                    <ComboBox ItemsSource="{Binding AvailableServerIds}"
                              SelectedItem="{Binding ServerId, Mode=TwoWay}"
                              Text="{Binding ServerId, Mode=TwoWay}"
                              IsEditable="True" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="DbName"/>
                    <TextBox Text="{Binding DbName, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="UserId"/>
                    <TextBox Text="{Binding UserId, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Password"/>
                    <TextBox Text="{Binding Password, Mode=TwoWay}" Width="280" PasswordChar="●"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="ConnectionString"/>
                    <TextBox Text="{Binding ConnectionString, Mode=TwoWay}" Width="500" TextWrapping="Wrap"/>
                </StackPanel>

                <Separator Margin="0,12"/>
                <TextBlock Text="貼上連線字串拆解" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                <TextBlock Text="貼上完整連線字串後按「拆解」，工具會依目前 DatabaseType 把帳密 / 資料庫名拆出來、改寫成佔位符。"
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap"/>
                <TextBox Text="{Binding PasteInput, Mode=TwoWay}" Height="80" AcceptsReturn="True"
                         TextWrapping="Wrap"
                         PlaceholderText="例：Host=localhost;Port=5432;Database=mydb;Username=app;Password=…"/>
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <Button Classes="doc" Content="拆解" Command="{Binding ParseCommand}"/>
                    <Button Classes="doc" Content="清除" Command="{Binding ClearCommand}"/>
                </StackPanel>

                <Border IsVisible="{Binding HasParseResult}" Padding="10" Margin="0,8,0,0"
                        Background="#252528" CornerRadius="3">
                    <StackPanel Spacing="4" x:DataType="vm:DatabaseItemEditor">
                        <TextBlock Text="拆解預覽" FontWeight="SemiBold" Foreground="#E0E0E0"/>
                        <TextBlock Text="{Binding ParseResult.UserId, StringFormat='UserId：{0}'}" Foreground="#D0D0D0"/>
                        <TextBlock Text="{Binding ParseResult.Password, StringFormat='Password：{0}'}" Foreground="#D0D0D0"/>
                        <TextBlock Text="{Binding ParseResult.DbName, StringFormat='DbName：{0}'}" Foreground="#D0D0D0"/>
                        <TextBlock Text="{Binding ParseResult.RewrittenConnectionString, StringFormat='ConnectionString：{0}'}"
                                   Foreground="#D0D0D0" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding ParseResult.Errors}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#E55" FontSize="11" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding ParseResult.Warnings}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#E0A33A" FontSize="11" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                            <Button Classes="doc" Content="套用至此 Item" Command="{Binding ApplyCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="12,8" Background="#1F1F22">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="#FFFFFF"/>
                        <TextBlock Text="●" Foreground="#E0A33A" VerticalAlignment="Center"
                                   IsVisible="{Binding IsDirty}" ToolTip.Tip="尚未存檔"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#A0A0A0"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="doc" Content="儲存" Command="{Binding SaveCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Server" Command="{Binding AddServerCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Item" Command="{Binding AddItemCommand}" Margin="3"/>
                    <Button Classes="doc" Content="驗證" Command="{Binding ValidateCommand}" Margin="3"/>
                    <Button Classes="doc danger" Content="刪除" Command="{Binding DeleteCommand}" Margin="3"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="12,4" Background="#1F1F22">
            <TextBlock Text="{Binding StatusText}" Foreground="#A0A0A0" FontSize="11"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="10,6" Background="#252528"
                IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Foreground="#E0E0E0" Text="驗證結果"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="150" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}"/>
                                <TextBlock Text="{Binding Path}" Foreground="#A0A0A0" Width="220"/>
                                <TextBlock Text="{Binding Message}" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.4*">
            <TreeView Grid.Column="0"
                      ItemsSource="{Binding Roots}"
                      SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Icon}"/>
                            <TextBlock Text="{Binding Header}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
            </TreeView>

            <GridSplitter Grid.Column="1" Background="#3E3E42" ResizeDirection="Columns"/>

            <Border Grid.Column="2" Padding="14">
                <ScrollViewer>
                    <ContentControl Content="{Binding SelectedEditorContext}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
