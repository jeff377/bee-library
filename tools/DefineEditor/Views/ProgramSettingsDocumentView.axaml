<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:settings="using:Bee.Definition.Settings"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Bee.DefineEditor.Views.ProgramSettingsDocumentView"
             x:DataType="vm:ProgramSettingsDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="settings:ProgramCategory">
            <StackPanel x:DataType="settings:ProgramCategory" Spacing="2">
                <TextBlock Classes="h2" Text="ProgramCategory 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="Id"/>
                    <TextBox Text="{Binding Id, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="settings:ProgramItem">
            <StackPanel x:DataType="settings:ProgramItem" Spacing="2">
                <TextBlock Classes="h2" Text="ProgramItem 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="ProgId"/>
                    <TextBox Text="{Binding ProgId, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="BusinessObject"/>
                    <TextBox Text="{Binding BusinessObject, Mode=TwoWay}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="settings:ProgramSettings">
            <StackPanel Spacing="6">
                <TextBlock Classes="h2" Text="ProgramSettings（程式清單根節點）"/>
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="於工具列「+ Category」加入 ProgramCategory；選取 Category 後可「+ Program」加入該分類下的 ProgramItem。"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>
        <Border DockPanel.Dock="Top" Classes="titlebar" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="1">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Classes="h1" Text="{Binding Title}"/>
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource DirtyIndicator}"
                                 VerticalAlignment="Center"
                                 IsVisible="{Binding IsDirty}" ToolTip.Tip="尚未存檔"/>
                    </StackPanel>
                    <TextBlock Classes="path" Text="{Binding FilePath}"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="tool primary" Command="{Binding SaveCommand}" Margin="2" ToolTip.Tip="儲存（寫回 XML）">
                        <StackPanel Orientation="Horizontal" Spacing="6"><PathIcon Data="{StaticResource IconSave}"/><TextBlock Text="儲存" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="tool" Command="{Binding AddCategoryCommand}" Margin="2" ToolTip.Tip="新增 ProgramCategory">
                        <StackPanel Orientation="Horizontal" Spacing="6"><PathIcon Data="{StaticResource IconFolder}"/><TextBlock Text="Category" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="tool" Command="{Binding AddProgramCommand}" Margin="2" ToolTip.Tip="新增 ProgramItem（需先選取 Category）">
                        <StackPanel Orientation="Horizontal" Spacing="6"><PathIcon Data="{StaticResource IconBox}"/><TextBlock Text="Program" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="tool" Command="{Binding ValidateCommand}" Margin="2" ToolTip.Tip="跑靜態驗證">
                        <StackPanel Orientation="Horizontal" Spacing="6"><PathIcon Data="{StaticResource IconCheck}"/><TextBlock Text="驗證" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                    <Button Classes="tool danger" Command="{Binding DeleteCommand}" Margin="2" ToolTip.Tip="刪除目前選取的節點">
                        <StackPanel Orientation="Horizontal" Spacing="6"><PathIcon Data="{StaticResource IconDelete}"/><TextBlock Text="刪除" VerticalAlignment="Center"/></StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="statusbar" Padding="12,5">
            <TextBlock Classes="muted" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="surface-sunken" Padding="12,8" IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="h2" Text="驗證結果"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="160" Background="Transparent" BorderThickness="0" Margin="0,6,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Path}" Classes="muted" Width="240"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.2*">
            <TreeView Grid.Column="0" ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}" Padding="6,4">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Icon}"/>
                            <TextBlock Text="{Binding Header}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
            </TreeView>
            <GridSplitter Grid.Column="1" Background="{DynamicResource SplitterBrush}" ResizeDirection="Columns"/>
            <Border Grid.Column="2" Padding="18,14">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding SelectedEditorContext}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
