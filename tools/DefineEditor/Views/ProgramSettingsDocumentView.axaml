<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:settings="using:Bee.Definition.Settings"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Bee.DefineEditor.Views.ProgramSettingsDocumentView"
             x:DataType="vm:ProgramSettingsDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="settings:ProgramCategory">
            <StackPanel x:DataType="settings:ProgramCategory" Spacing="2">
                <TextBlock Classes="h2" Text="ProgramCategory 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="Id"/>
                    <TextBox Text="{Binding Id, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="settings:ProgramItem">
            <StackPanel x:DataType="settings:ProgramItem" Spacing="2">
                <TextBlock Classes="h2" Text="ProgramItem 屬性" Margin="0,0,0,8"/>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="ProgId"/>
                    <TextBox Text="{Binding ProgId, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="DisplayName"/>
                    <TextBox Text="{Binding DisplayName, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row">
                    <TextBlock Classes="label" Text="BusinessObject"/>
                    <TextBox Text="{Binding BusinessObject, Mode=TwoWay}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="settings:ProgramSettings">
            <StackPanel Spacing="6">
                <TextBlock Classes="h2" Text="ProgramSettings（程式清單根節點）"/>
                <TextBlock Classes="muted" TextWrapping="Wrap"
                           Text="於工具列「+ Category」加入 ProgramCategory；選取 Category 後可「+ Program」加入該分類下的 ProgramItem。"/>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>

        <Border DockPanel.Dock="Bottom" Classes="statusbar" Padding="12,5">
            <TextBlock Classes="muted" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="surface-sunken" Padding="12,8" IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="h2" Text="驗證結果"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="160" Background="Transparent" BorderThickness="0" Margin="0,6,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Path}" Classes="muted" Width="240"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.2*">
            <TreeView Grid.Column="0" ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}" Padding="6,4">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Classes="inner-icon" Data="{Binding Icon, Converter={StaticResource IconKeyToGeometry}}"/>
                            <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="新增 ProgramCategory"
                                  Command="{Binding AddCategoryCommand}"
                                  IsVisible="{Binding SelectedKindIsRoot}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconAdd}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="新增 ProgramItem"
                                  Command="{Binding AddProgramCommand}"
                                  IsVisible="{Binding SelectedKindIsCategory}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconBox}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator IsVisible="{Binding SelectedKindCanDelete}"/>
                        <MenuItem Header="刪除"
                                  Command="{Binding DeleteCommand}"
                                  IsVisible="{Binding SelectedKindCanDelete}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconDelete}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>
            <GridSplitter Grid.Column="1" Background="{DynamicResource SplitterBrush}" ResizeDirection="Columns"/>
            <Border Grid.Column="2" Padding="18,14">
                <ScrollViewer Classes="props-pane" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding SelectedEditorContext}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
