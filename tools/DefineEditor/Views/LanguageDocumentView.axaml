<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:lang="using:Bee.Definition.Language"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Bee.DefineEditor.Views.LanguageDocumentView"
             x:DataType="vm:LanguageDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="lang:LanguageResource">
            <StackPanel x:DataType="lang:LanguageResource" Spacing="6">
                <TextBlock Text="LanguageResource 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Namespace"/>
                    <TextBox Text="{Binding Namespace, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Lang (BCP-47)"/>
                    <TextBox Text="{Binding Lang, Mode=TwoWay}" Width="200"/>
                </StackPanel>
                <TextBlock Text="（Namespace 通常對應 ProgId / 模組名稱；Lang 例：zh-TW、en-US。）"
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="lang:LanguageItem">
            <StackPanel x:DataType="lang:LanguageItem" Spacing="6">
                <TextBlock Text="LanguageItem 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Key (sub-key)"/>
                    <TextBox Text="{Binding Key, Mode=TwoWay}" Width="320"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Value"/>
                    <TextBox Text="{Binding Value, Mode=TwoWay}" Width="420" AcceptsReturn="True" TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="lang:LanguageEnum">
            <StackPanel x:DataType="lang:LanguageEnum" Spacing="6">
                <TextBlock Text="LanguageEnum 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Name"/>
                    <TextBox Text="{Binding Name, Mode=TwoWay}" Width="280"/>
                </StackPanel>
                <TextBlock Text="（用工具列「新增 Entry」加入 code/text 對。）"
                           Foreground="#A0A0A0" FontSize="11" TextWrapping="Wrap"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="lang:LanguageEnumEntry">
            <StackPanel x:DataType="lang:LanguageEnumEntry" Spacing="6">
                <TextBlock Text="LanguageEnumEntry 屬性" FontWeight="Bold" FontSize="13" Margin="0,0,0,6"/>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Code"/>
                    <TextBox Text="{Binding Code, Mode=TwoWay}" Width="200"/>
                </StackPanel>
                <StackPanel Classes="row">
                    <TextBlock Classes="label" Text="Text"/>
                    <TextBox Text="{Binding Text, Mode=TwoWay}" Width="320"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>
        <Border DockPanel.Dock="Top" Padding="12,8" Background="#1F1F22">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="15" Foreground="#FFFFFF"/>
                        <TextBlock Text="●" Foreground="#E0A33A" VerticalAlignment="Center"
                                   IsVisible="{Binding IsDirty}" ToolTip.Tip="尚未存檔"/>
                    </StackPanel>
                    <TextBlock Text="{Binding FilePath}" FontSize="11" Foreground="#A0A0A0"/>
                </StackPanel>
                <WrapPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Classes="doc" Content="儲存" Command="{Binding SaveCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Item" Command="{Binding AddItemCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Enum" Command="{Binding AddEnumCommand}" Margin="3"/>
                    <Button Classes="doc" Content="新增 Entry" Command="{Binding AddEntryCommand}" Margin="3"/>
                    <Button Classes="doc" Content="驗證" Command="{Binding ValidateCommand}" Margin="3"/>
                    <Button Classes="doc danger" Content="刪除" Command="{Binding DeleteCommand}" Margin="3"/>
                </WrapPanel>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="12,4" Background="#1F1F22">
            <TextBlock Text="{Binding StatusText}" Foreground="#A0A0A0" FontSize="11"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Padding="10,6" Background="#252528"
                IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" FontWeight="SemiBold" Foreground="#E0E0E0" Text="驗證結果"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="150" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}"/>
                                <TextBlock Text="{Binding Path}" Foreground="#A0A0A0" Width="220"/>
                                <TextBlock Text="{Binding Message}" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.2*">
            <TreeView Grid.Column="0"
                      ItemsSource="{Binding Roots}"
                      SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="{Binding Icon}"/>
                            <TextBlock Text="{Binding Header}"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
            </TreeView>

            <GridSplitter Grid.Column="1" Background="#3E3E42" ResizeDirection="Columns"/>

            <Border Grid.Column="2" Padding="14">
                <ScrollViewer>
                    <ContentControl Content="{Binding SelectedEditorContext}"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
