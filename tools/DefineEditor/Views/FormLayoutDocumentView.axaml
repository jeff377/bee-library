<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Bee.DefineEditor.ViewModels"
             xmlns:loc="using:Bee.DefineEditor.Markup"
             xmlns:behaviors="using:Bee.DefineEditor.Behaviors"
             xmlns:models="using:Bee.DefineEditor.Models"
             xmlns:layouts="using:Bee.Definition.Layouts"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="Bee.DefineEditor.Views.FormLayoutDocumentView"
             x:DataType="vm:FormLayoutDocumentViewModel"
             x:CompileBindings="True">

    <UserControl.DataTemplates>
        <DataTemplate DataType="layouts:FormLayout">
            <StackPanel x:DataType="layouts:FormLayout" Spacing="2">
                <TextBlock Classes="h2" Text="{loc:Loc FormLayout_Props}" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="LayoutId"/><TextBox Text="{Binding LayoutId, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="ProgId"/><TextBox Text="{Binding ProgId, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Caption"/><TextBox Text="{Binding Caption, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short"><TextBlock Classes="label" Text="ColumnCount"/><TextBox Text="{Binding ColumnCount, Mode=TwoWay}"/></DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="layouts:LayoutSection">
            <StackPanel x:DataType="layouts:LayoutSection" Spacing="2">
                <TextBlock Classes="h2" Text="{loc:Loc FormLayout_SectionProps}" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Name"/><TextBox Text="{Binding Name, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Caption"/><TextBox Text="{Binding Caption, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="ShowCaption"/><CheckBox IsChecked="{Binding ShowCaption, Mode=TwoWay}"/></DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="layouts:LayoutField">
            <StackPanel x:DataType="layouts:LayoutField" Spacing="2">
                <TextBlock Classes="h2" Text="{loc:Loc FormLayout_FieldProps}" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="FieldName"/><TextBox Text="{Binding FieldName, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Caption"/><TextBox Text="{Binding Caption, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short">
                    <TextBlock Classes="label" Text="ControlType"/>
                    <ComboBox ItemsSource="{x:Static vm:EditorOptions.ControlTypes}" SelectedItem="{Binding ControlType, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row short"><TextBlock Classes="label" Text="RowSpan"/><TextBox Text="{Binding RowSpan, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short"><TextBlock Classes="label" Text="ColumnSpan"/><TextBox Text="{Binding ColumnSpan, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="DisplayFormat"/><TextBox Text="{Binding DisplayFormat, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="NumberFormat"/><TextBox Text="{Binding NumberFormat, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Visible"/><CheckBox IsChecked="{Binding Visible, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="ReadOnly"/><CheckBox IsChecked="{Binding ReadOnly, Mode=TwoWay}"/></DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="layouts:LayoutGrid">
            <StackPanel x:DataType="layouts:LayoutGrid" Spacing="2">
                <TextBlock Classes="h2" Text="{loc:Loc FormLayout_GridProps}" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="TableName"/><TextBox Text="{Binding TableName, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Caption"/><TextBox Text="{Binding Caption, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short">
                    <TextBlock Classes="label" Text="AllowActions"/>
                    <ComboBox ItemsSource="{x:Static vm:EditorOptions.GridAllowActions}" SelectedItem="{Binding AllowActions, Mode=TwoWay}"/>
                </DockPanel>
            </StackPanel>
        </DataTemplate>

        <DataTemplate DataType="layouts:LayoutColumn">
            <StackPanel x:DataType="layouts:LayoutColumn" Spacing="2">
                <TextBlock Classes="h2" Text="{loc:Loc FormLayout_ColumnProps}" Margin="0,0,0,8"/>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="FieldName"/><TextBox Text="{Binding FieldName, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Caption"/><TextBox Text="{Binding Caption, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row short">
                    <TextBlock Classes="label" Text="ControlType"/>
                    <ComboBox ItemsSource="{x:Static vm:EditorOptions.ControlTypes}" SelectedItem="{Binding ControlType, Mode=TwoWay}"/>
                </DockPanel>
                <DockPanel Classes="row short"><TextBlock Classes="label" Text="Width"/><TextBox Text="{Binding Width, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="Visible"/><CheckBox IsChecked="{Binding Visible, Mode=TwoWay}"/></DockPanel>
                <DockPanel Classes="row"><TextBlock Classes="label" Text="ReadOnly"/><CheckBox IsChecked="{Binding ReadOnly, Mode=TwoWay}"/></DockPanel>
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <DockPanel>

        <Border DockPanel.Dock="Bottom" Classes="statusbar" Padding="12,5">
            <TextBlock Classes="muted" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis"/>
        </Border>

        <Border DockPanel.Dock="Bottom" Classes="surface-sunken" Padding="12,8" IsVisible="{Binding Issues.Count}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="h2" Text="{loc:Loc Section_ValidationResults}"/>
                <ListBox ItemsSource="{Binding Issues}" MaxHeight="160" Background="Transparent" BorderThickness="0" Margin="0,6,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:ValidationIssue">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding Icon}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Path}" Classes="muted" Width="240"/>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid ColumnDefinitions="*,4,1.2*">
            <TreeView Grid.Column="0" ItemsSource="{Binding Roots}" SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}" Padding="6,4">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:SettingsTreeNode">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Classes="inner-icon" Data="{Binding Icon, Converter={StaticResource IconKeyToGeometry}}"/>
                            <TextBlock Text="{Binding Header}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
                <TreeView.Styles>
                    <Style Selector="TreeViewItem" x:DataType="models:SettingsTreeNode">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                    </Style>
                </TreeView.Styles>
                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="{loc:Loc FormLayout_AddSection}"
                                  Command="{Binding AddSectionCommand}"
                                  IsVisible="{Binding SelectedKindIsSectionsGroup}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconSection}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{loc:Loc FormLayout_AddField}"
                                  Command="{Binding AddLayoutFieldCommand}"
                                  IsVisible="{Binding SelectedKindIsSection}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconColumn}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{loc:Loc FormLayout_AddGrid}"
                                  Command="{Binding AddGridCommand}"
                                  IsVisible="{Binding SelectedKindIsDetailsGroup}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconGrid}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{loc:Loc FormLayout_AddColumn}"
                                  Command="{Binding AddLayoutColumnCommand}"
                                  IsVisible="{Binding SelectedKindIsGrid}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconColumn}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator IsVisible="{Binding ShowDeleteSeparator}"/>
                        <MenuItem Header="{loc:Loc Action_Delete}"
                                  Command="{Binding DeleteCommand}"
                                  IsVisible="{Binding SelectedKindCanDelete}">
                            <MenuItem.Icon>
                                <PathIcon Data="{StaticResource IconDelete}" Width="14" Height="14"/>
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>
            <GridSplitter Grid.Column="1" Background="{DynamicResource SemiColorBorder}" ResizeDirection="Columns"/>
            <Border Grid.Column="2" Padding="18,14">
                <ScrollViewer Classes="props-pane" HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding SelectedEditorContext}"
                                    behaviors:DirtyTracking.IsEnabled="True"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
