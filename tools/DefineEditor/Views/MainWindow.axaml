<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Bee.DefineEditor.ViewModels"
        xmlns:models="using:Bee.DefineEditor.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="720"
        x:Class="Bee.DefineEditor.Views.MainWindow"
        x:Name="WindowRoot"
        x:DataType="vm:MainWindowViewModel"
        x:CompileBindings="True"
        Icon="/Assets/avalonia-logo.ico"
        Width="1200" Height="720"
        Title="Bee.DefineEditor — 定義檔方案維護">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- 上方工具列 -->
        <Border DockPanel.Dock="Top" Classes="titlebar" Padding="10,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                    <Button Classes="tool primary" Click="OnOpenSolutionClick"
                            ToolTip.Tip="開啟 DefinePath 方案資料夾">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <PathIcon Data="{StaticResource IconFolder}"/>
                            <TextBlock Text="開啟方案" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="{Binding StatusText}"
                           Classes="muted" VerticalAlignment="Center"
                           Margin="14,0" TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="2" Classes="tool icon"
                        Command="{Binding ToggleThemeCommand}"
                        ToolTip.Tip="切換淺色 / 深色主題">
                    <PathIcon Data="{StaticResource IconSun}"/>
                </Button>
            </Grid>
        </Border>

        <!-- 主體：左方案樹 + 右文件 tab 區 -->
        <Grid ColumnDefinitions="320,4,*">
            <TreeView Grid.Column="0"
                      ItemsSource="{Binding Nodes}"
                      SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                      Padding="6,4">
                <TreeView.ItemTemplate>
                    <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:DefineNode">
                        <TextBlock Text="{Binding Name}" Padding="2,3"/>
                    </TreeDataTemplate>
                </TreeView.ItemTemplate>
            </TreeView>

            <GridSplitter Grid.Column="1" Background="{DynamicResource SplitterBrush}" ResizeDirection="Columns"/>

            <Grid Grid.Column="2">
                <!-- 多文件 tab 區（IDE 風） -->
                <TabControl ItemsSource="{Binding OpenDocuments}"
                            SelectedItem="{Binding ActiveDocument, Mode=TwoWay}"
                            IsVisible="{Binding HasOpenDocuments}"
                            Padding="0">
                    <TabControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:DocumentViewModelBase">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" MinWidth="120">
                                <TextBlock Grid.Column="0" Text="{Binding TabIcon}"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Grid.Column="1" Text="{Binding Title}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" MaxWidth="260"
                                           ToolTip.Tip="{Binding DocumentKey}"/>
                                <Ellipse Grid.Column="2" Width="6" Height="6"
                                         Fill="{DynamicResource DirtyIndicator}"
                                         VerticalAlignment="Center" Margin="6,0,0,0"
                                         IsVisible="{Binding IsDirty}"
                                         ToolTip.Tip="尚未存檔"/>
                                <Button Grid.Column="3" Classes="tabclose"
                                        Command="{Binding #WindowRoot.((vm:MainWindowViewModel)DataContext).CloseDocumentCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="關閉分頁">
                                    <PathIcon Data="{StaticResource IconClear}" Width="10" Height="10"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                    <TabControl.ContentTemplate>
                        <DataTemplate x:DataType="vm:DocumentViewModelBase">
                            <ContentControl Content="{Binding}"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>

                <!-- 歡迎畫面（無已開分頁） -->
                <Border Padding="40" IsVisible="{Binding !HasOpenDocuments}">
                    <StackPanel Spacing="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource IconFolder}" Width="48" Height="48"
                                  Foreground="{DynamicResource MutedForeground}"/>
                        <TextBlock Classes="muted" HorizontalAlignment="Center"
                                   Text="（於左側方案樹選取定義檔開啟分頁；點已開過的檔會切換到既有分頁）"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>

</Window>
