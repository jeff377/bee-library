<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Bee.DefineEditor.App"
             xmlns:local="using:Bee.DefineEditor"
             xmlns:conv="using:Bee.DefineEditor.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- 仿 VS Code 的 sidebar 配色：Light 比編輯區（白）深一階、
                     Dark 比編輯區淺一階，讓方案樹與定義編輯區有明確區隔。
                     色值取自 VS Code 預設主題的 sideBar.background。 -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SidebarBackground">#F3F3F3</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SidebarBackground">#252526</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://Semi.Avalonia/Index.axaml"/>
        <StyleInclude Source="/Styles/DocumentStyles.axaml"/>
    </Application.Styles>
</Application>
