<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Bee.DefineEditor.App"
             xmlns:local="using:Bee.DefineEditor"
             xmlns:conv="using:Bee.DefineEditor.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <conv:IconKeyToGeometryConverter x:Key="IconKeyToGeometry"/>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://Semi.Avalonia/Index.axaml"/>
        <StyleInclude Source="/Styles/DocumentStyles.axaml"/>
    </Application.Styles>
</Application>
