<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="using:Bee.DefineEditor.Models">

    <Styles.Resources>
        <!-- =================================================================
             圖示資料：Material Design Icons (Apache-2.0)，採 24×24 path data
