        <StreamGeometry x:Key="IconParse">M21,11.5V12.5L20,12V20H4V12L3,12.5V11.5L4,11V4H20V11L21,11.5M18,6H6V11.5L12,9L18,11.5V6M18,12.62L12,15.12L6,12.62V18H18V12.62Z</StreamGeometry>
        <StreamGeometry x:Key="IconClear">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z</StreamGeometry>
