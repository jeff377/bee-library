    </Styles.Resources>

    <!-- =================================================================
         工具列按鈕（含圖示 + 短標籤 + tooltip）
         ================================================================= -->
    <Style Selector="Button.tool">
        <Setter Property="Background" Value="{DynamicResource ToolButtonBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource ToolButtonForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ToolButtonBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="9,5"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="28"/>
    </Style>
    <Style Selector="Button.tool:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToolButtonBackgroundHover}"/>
        <Setter Property="Foreground" Value="{DynamicResource ToolButtonForegroundHover}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource ToolButtonBorderHover}"/>
    </Style>
    <Style Selector="Button.tool:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToolButtonBackgroundPressed}"/>
    </Style>
    <Style Selector="Button.tool:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToolButtonBackgroundDisabled}"/>
        <Setter Property="Foreground" Value="{DynamicResource ToolButtonForegroundDisabled}"/>
    </Style>

    <!-- 主行為按鈕（藍底，例：儲存） -->
    <Style Selector="Button.tool.primary">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackground}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackground}"/>
    </Style>
    <Style Selector="Button.tool.primary:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundHover}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBackgroundHover}"/>
    </Style>
    <Style Selector="Button.tool.primary:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource PrimaryButtonBackgroundPressed}"/>
    </Style>

    <!-- 危險按鈕（紅底，例：刪除） -->
    <Style Selector="Button.tool.danger">
        <Setter Property="Background" Value="{DynamicResource DangerButtonBackground}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerButtonBackground}"/>
    </Style>
    <Style Selector="Button.tool.danger:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource DangerButtonBackgroundHover}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DangerButtonBackgroundHover}"/>
    </Style>

    <!-- 圖示按鈕內部 PathIcon -->
    <Style Selector="Button.tool PathIcon">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- =================================================================
         屬性面板響應式排版（label + 自由伸展的 input）
         ================================================================= -->
    <Style Selector="DockPanel.row">
        <Setter Property="LastChildFill" Value="True"/>
        <Setter Property="Margin" Value="0,3"/>
    </Style>
    <Style Selector="DockPanel.row > TextBlock.label">
        <Setter Property="DockPanel.Dock" Value="Left"/>
        <Setter Property="Width" Value="160"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource PropertyLabelForeground}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="DockPanel.row > TextBox">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="MaxWidth" Value="600"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="DockPanel.row > ComboBox">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="MaxWidth" Value="600"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="DockPanel.row > CheckBox">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- 短欄位（數字、Lang code）用 .row.short 縮限到固定寬 -->
    <Style Selector="DockPanel.row.short > TextBox">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Width" Value="120"/>
    </Style>
    <Style Selector="DockPanel.row.short > ComboBox">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Width" Value="200"/>
    </Style>

    <!-- =================================================================
         面板區塊背景（主題感知）
         ================================================================= -->
    <Style Selector="Border.surface">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
    </Style>
    <Style Selector="Border.surface-sunken">
        <Setter Property="Background" Value="{DynamicResource SunkenBackground}"/>
    </Style>
    <Style Selector="Border.titlebar">
        <Setter Property="Background" Value="{DynamicResource TitleBarBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource TitleBarBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style Selector="Border.statusbar">
        <Setter Property="Background" Value="{DynamicResource StatusBarBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource TitleBarBorder}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource HeadingForeground}"/>
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource HeadingForeground}"/>
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}"/>
        <Setter Property="FontSize" Value="11"/>
    </Style>
    <Style Selector="TextBlock.path">
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontFamily" Value="ui-monospace, Menlo, Consolas, monospace"/>
    </Style>

    <!-- TreeView 主題色 -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="{DynamicResource TreeBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
    </Style>
    <Style Selector="TreeViewItem">
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- 字型：統一走 Inter（已透過 Program.cs WithInterFont 註冊） -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="fonts:Inter#Inter, $Default"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
    </Style>
    <Style Selector="UserControl">
        <Setter Property="FontFamily" Value="fonts:Inter#Inter, $Default"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
    </Style>

    <!-- =================================================================
         Tab 按鈕（IDE 風）+ 關閉鈕
         ================================================================= -->
    <Style Selector="TabControl">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
    </Style>
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="TabItem:selected">
        <Setter Property="Foreground" Value="{DynamicResource HeadingForeground}"/>
        <Setter Property="Background" Value="{DynamicResource SurfaceBackground}"/>
    </Style>
    <Style Selector="TabItem:pointerover">
        <Setter Property="Foreground" Value="{DynamicResource Foreground}"/>
    </Style>

    <!-- Tab 內的關閉按鈕 -->
    <Style Selector="Button.tabclose">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Foreground" Value="{DynamicResource MutedForeground}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.tabclose:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToolButtonBackgroundHover}"/>
        <Setter Property="Foreground" Value="{DynamicResource HeadingForeground}"/>
    </Style>

    <!-- 表格按鈕（行內用：未來擴充） -->
    <Style Selector="Button.icon">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Foreground" Value="{DynamicResource ToolButtonForeground}"/>
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ToolButtonBackgroundHover}"/>
        <Setter Property="Foreground" Value="{DynamicResource ToolButtonForegroundHover}"/>
    </Style>
    <Style Selector="Button.icon PathIcon">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
    </Style>

</Styles>
