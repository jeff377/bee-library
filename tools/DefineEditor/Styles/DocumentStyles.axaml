        <StreamGeometry x:Key="IconServer">M4,1H20A1,1 0 0,1 21,2V6A1,1 0 0,1 20,7H4A1,1 0 0,1 3,6V2A1,1 0 0,1 4,1M4,9H20A1,1 0 0,1 21,10V14A1,1 0 0,1 20,15H4A1,1 0 0,1 3,14V10A1,1 0 0,1 4,9M4,17H20A1,1 0 0,1 21,18V22A1,1 0 0,1 20,23H4A1,1 0 0,1 3,22V18A1,1 0 0,1 4,17M9,5H10V3H9V5M9,13H10V11H9V13M9,21H10V19H9V21M5,3V5H7V3H5M5,11V13H7V11H5M5,19V21H7V19H5Z</StreamGeometry>
    </Styles.Resources>

    <!-- =================================================================
         工具列按鈕（含圖示 + 短標籤 + tooltip）— 外觀交給 Semi，僅留尺寸
         ================================================================= -->
    <Style Selector="Button.tool">
        <Setter Property="Padding" Value="11,6"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="32"/>
    </Style>

    <!-- 主行為按鈕（例：儲存）：Semi SolidButton 主題 + Primary 語意 class -->
    <Style Selector="Button.tool.Primary">
        <Setter Property="Theme" Value="{DynamicResource SolidButton}"/>
    </Style>

    <!-- 危險按鈕（例：刪除）：Semi SolidButton 主題 + Danger 語意 class -->
    <Style Selector="Button.tool.Danger">
        <Setter Property="Theme" Value="{DynamicResource SolidButton}"/>
    </Style>

    <!-- 圖示按鈕內部 PathIcon -->
    <Style Selector="Button.tool PathIcon">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- =================================================================
         屬性面板響應式排版（label + 自由伸展的 input）
         ================================================================= -->
    <Style Selector="DockPanel.row">
        <Setter Property="LastChildFill" Value="True"/>
        <Setter Property="Margin" Value="0,4"/>
    </Style>
    <Style Selector="DockPanel.row > TextBlock.label">
        <Setter Property="DockPanel.Dock" Value="Left"/>
        <Setter Property="Width" Value="180"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText2}"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    <!-- NOTE: no MaxWidth on stretched editors. `Stretch` + `MaxWidth` makes
         Avalonia centre the element inside the leftover slot once the pane
         grows past the cap, breaking left alignment with fixed-width rows
         (`.short` ComboBox). Width-capped fields belong to `.row.short`. -->
    <Style Selector="DockPanel.row > TextBox">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="DockPanel.row > ComboBox">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>
    <Style Selector="DockPanel.row > CheckBox">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- 短欄位（數字、Lang code）用 .row.short 縮限到固定寬 -->
    <Style Selector="DockPanel.row.short > TextBox">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Width" Value="140"/>
    </Style>
    <Style Selector="DockPanel.row.short > ComboBox">
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Width" Value="220"/>
    </Style>

    <!-- =================================================================
         面板區塊背景（Semi 分層 token：Bg0 主面、Bg1 沉面、Bg2 抬升面）
         ================================================================= -->
    <Style Selector="Border.surface">
        <Setter Property="Background" Value="{DynamicResource SemiColorBackground0}"/>
    </Style>
    <Style Selector="Border.surface-sunken">
        <Setter Property="Background" Value="{DynamicResource SemiColorBackground1}"/>
    </Style>
    <Style Selector="Border.titlebar">
        <Setter Property="Background" Value="{DynamicResource SemiColorBackground2}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style Selector="Border.statusbar">
        <Setter Property="Background" Value="{DynamicResource SemiColorBackground1}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource SemiColorBorder}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
    </Style>

    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style Selector="TextBlock.muted">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText2}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>
    <Style Selector="TextBlock.path">
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText2}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="ui-monospace, Menlo, Consolas, monospace"/>
    </Style>

    <!-- 左側樹面板與編輯面區隔（沉面層） -->
    <Style Selector="TreeView">
        <Setter Property="Background" Value="{DynamicResource SemiColorBackground1}"/>
    </Style>
    <Style Selector="TreeViewItem">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Padding" Value="2,4"/>
    </Style>
    <!-- 樹節點 / 分頁 head 用的 PathIcon -->
    <Style Selector="PathIcon.tree-icon">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="PathIcon.tab-icon">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <!-- 屬性面板捲動區：捲軸不蓋輸入框，獨佔右側欄位 -->
    <Style Selector="ScrollViewer.props-pane">
        <Setter Property="AllowAutoHide" Value="False"/>
        <Setter Property="Padding" Value="0,0,4,0"/>
    </Style>

    <!-- 編輯器內層樹節點圖示 -->
    <Style Selector="PathIcon.inner-icon">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Height" Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- 字型：統一走 Inter（已透過 Program.cs WithInterFont 註冊） -->
    <Style Selector="Window">
        <Setter Property="FontFamily" Value="fonts:Inter#Inter, $Default"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Background" Value="{DynamicResource SemiColorBackground0}"/>
    </Style>
    <Style Selector="UserControl">
        <Setter Property="FontFamily" Value="fonts:Inter#Inter, $Default"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <!-- =================================================================
         Tab（IDE 風密度）+ 關閉鈕 — 配色交給 Semi，僅留尺寸
         ================================================================= -->
    <Style Selector="TabItem">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Padding" Value="14,6"/>
    </Style>

    <!-- Tab 內的關閉按鈕（無框小鈕，hover 走 Semi fill） -->
    <Style Selector="Button.tabclose">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="3"/>
        <Setter Property="Margin" Value="6,0,0,0"/>
        <Setter Property="CornerRadius" Value="3"/>
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText2}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.tabclose:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}"/>
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}"/>
    </Style>

    <!-- 表格按鈕（行內用：未來擴充） -->
    <Style Selector="Button.icon">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="7"/>
        <Setter Property="CornerRadius" Value="3"/>
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource SemiColorFill1}"/>
        <Setter Property="Foreground" Value="{DynamicResource SemiColorText0}"/>
    </Style>
    <Style Selector="Button.icon PathIcon">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
    </Style>

</Styles>
