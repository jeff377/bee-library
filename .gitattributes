# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source code
*.cs text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.sln text eol=lf
*.slnx text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Configuration
*.json text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.editorconfig text eol=lf

# Binary
*.png binary
*.snupkg binary
*.nupkg binary
