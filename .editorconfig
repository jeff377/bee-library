root = true

# All files
[*]
indent_style = space
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# C# files
[*.cs]
indent_size = 4

# 編譯期檢查：移除多餘 using 指令
dotnet_diagnostic.IDE0005.severity = warning

# 編譯期檢查：使用集合初始化運算式
dotnet_diagnostic.IDE0028.severity = warning

# 編譯期檢查：namespace 末段不得與其中的類別／介面同名
dotnet_diagnostic.CA1724.severity = warning

# XML project files
[*.{csproj,props,targets}]
indent_size = 2

# XML files
[*.xml]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
indent_size = 2
trim_trailing_whitespace = false

# Solution files
[*.{sln,slnx}]
indent_size = 2
