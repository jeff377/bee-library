<?xml version="1.0" encoding="utf-8" ?>
<!--
  SonarCloud 掃描設定。

  此檔由 .github/workflows/build-ci.yml 的 SonarScanner Begin step 透過
  /s:"$GITHUB_WORKSPACE/SonarQube.Analysis.xml" 引用。

  命令列保留的參數（不放此檔）：
    /k:                專案 key
    /o:                organization
    /d:sonar.token     SONAR_TOKEN secret，避免進入版控
    /d:sonar.host.url  SonarCloud 入口（dotnet scanner 部分版本要求命令列）

  設計原則：與專案內檔案 / 規則綁定的設定放此檔，跟 repo 一起 PR review。
  與帳號／組織通用的設定（quality profile、quality gate）留 SonarCloud UI。

  注意：SonarScanner for .NET 的 /s: 參數要求 XML 格式（SonarQube.Analysis.xml），
  不接受 Java sonar-project.properties 格式。
-->
<SonarQubeAnalysisProperties xmlns="http://www.sonarsource.com/msbuild/integration/2015/1">
  <!-- 覆蓋率報告 -->
  <Property Name="sonar.cs.opencover.reportsPaths">**/TestResults/**/coverage.opencover.xml</Property>

  <!--
    不納入覆蓋率計算的目錄。
    - tests/、samples/：測試與範例本身不需被覆蓋
    （MySQL、Oracle 已在主 CI 加入 service container，移出排除清單。）
  -->
  <Property Name="sonar.coverage.exclusions">tests/**,samples/**</Property>

  <!--
    排除「設計上對稱實作」的重複行偵測。

    1. **/Providers/**
       Bee.Db.Providers 每個 DB（SqlServer/PostgreSql/Sqlite/MySql/Oracle）必須
       各自實作 SQL dialect、元數據查詢、schema 操作，本質上就是對稱重複，無法
       以共用基底消除。詳見 docs/plans/plan-symmetric-types-refactor.md。

    2. src/Bee.Web.Blazor.*/Components/**、src/Bee.Web.Blazor.*/DataObjects/**、
       src/Bee.UI.Maui/DataObjects/**
       Blazor Server / Blazor Wasm / MAUI 三套 UI 元件庫的執行環境根本不同
       （SignalR vs Browser .NET vs Native），plan-blazor-web-integration §
       「決策：兩套元件庫各自獨立維護，不共用 UI 元件」與 plan-maui-integration
       §「同樣 schema/contract，UI 與 connector 來源不同」明確規範各自獨立。
       FormDataObject / FormPage / DynamicForm / DynamicGrid / BeeLoginPanel /
       BeeAccessTokenProvider 皆為刻意鏡像，CPD 重複行為預期行為。
  -->
  <Property Name="sonar.cpd.exclusions">**/Providers/**,src/Bee.Web.Blazor.*/Components/**,src/Bee.Web.Blazor.*/DataObjects/**,src/Bee.UI.Maui/DataObjects/**</Property>
</SonarQubeAnalysisProperties>
